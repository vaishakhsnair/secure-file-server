# Where files are stored and served from.
STORAGE_DIR=./data

# Uploads are blocked by default.
UPLOAD_ENABLED=false

# Credentials used for HTTP Basic auth on /upload.
UPLOAD_USERNAME=uploader
UPLOAD_PASSWORD=change-me

# Max upload size in bytes (10 MiB).
MAX_UPLOAD_BYTES=10485760

# Keep false for safety unless overwrite is required.
ALLOW_OVERWRITE=false
