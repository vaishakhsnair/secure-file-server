# Where files are stored and served from.
STORAGE_DIR=./data

# Host UID/GID for docker-compose container user mapping.
PUID=1000
PGID=1000

# Uploads are blocked by default.
UPLOAD_ENABLED=false

# Credentials used for HTTP Basic auth on /upload.
UPLOAD_USERNAME=uploader
UPLOAD_PASSWORD=change-me

# GUI auth credentials (defaults to upload credentials if omitted).
GUI_USERNAME=uploader
GUI_PASSWORD=change-me

# Required for signed GUI session cookies.
GUI_SESSION_SECRET=replace-with-long-random-secret

# Set true only when served via HTTPS.
GUI_COOKIE_SECURE=false

# GUI session lifetime in seconds (default 8 hours).
GUI_SESSION_TTL_SECONDS=28800

# Max upload size in bytes (10 MiB).
MAX_UPLOAD_BYTES=10485760

# Keep false for safety unless overwrite is required.
ALLOW_OVERWRITE=false
